    <rdf:Description rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#WorkflowExecution">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#PlanExecution"/>
    </rdf:Description>
    


    <!-- http://www.opengis.net/ont/geosparql#Feature -->

    <rdf:Description rdf:about="http://www.opengis.net/ont/geosparql#Feature">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity"/>
    </rdf:Description>
    


    <!-- http://www.opengis.net/ont/geosparql#Geometry -->

    <rdf:Description rdf:about="http://www.opengis.net/ont/geosparql#Geometry">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity"/>
    </rdf:Description>
    


    <!-- http://www.opengis.net/ont/geosparql#SpatialObject -->

    <rdf:Description rdf:about="http://www.opengis.net/ont/geosparql#SpatialObject">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rsm/geosparql_adapter/rgeo#Feature -->

    <rdf:Description rdf:about="https://cdm.ovh/rsm/geosparql_adapter/rgeo#Feature">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rsm/geosparql_adapter/rgeo#Geometry -->

    <rdf:Description rdf:about="https://cdm.ovh/rsm/geosparql_adapter/rgeo#Geometry">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
    </rdf:Description>
    


    <!-- https://cdm.ovh/rsm/geosparql_adapter/rgeo#LinearThing -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/geosparql_adapter/rgeo#LinearThing">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs#LinearElementForLinearReferencing"/>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/linearReferencing/rlrs#DistanceExpression -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/linearReferencing/rlrs#DistanceExpression">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs#QuantityValue"/>
        <rdfs:comment xml:lang="en">as per ISO 19148</rdfs:comment>
        <rdfs:label xml:lang="en">Distance expression</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/linearReferencing/rlrs#FullLinearPosition -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/linearReferencing/rlrs#FullLinearPosition">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs#LinearPosition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs#hasPositionExpression"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs#PositionExpression"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs#InstrinsicPosition"/>
        <rdfs:comment xml:lang="en">Positioning using an explicit linear coordinate individual</rdfs:comment>
        <rdfs:label>Full linear position</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/linearReferencing/rlrs#InstrinsicPosition -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/linearReferencing/rlrs#InstrinsicPosition">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs#LinearPosition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs#hasPositionExpression"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs#IntrinsicPositionExpression"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Instrinsic position</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/linearReferencing/rlrs#IntrinsicPositionExpression -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/linearReferencing/rlrs#IntrinsicPositionExpression">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs#LinearPositionExpression"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs#linearElement"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/topology/topo#LinearElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs#icValue"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs#PositionExpression"/>
        <rdfs:comment xml:lang="en">Intrinsic positions can only use a topo:LinearElement as Linear Element in the sense of ISO 19148, hence the property restriction.</rdfs:comment>
        <rdfs:label xml:lang="en">Intrinsic position expression</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/linearReferencing/rlrs#LinearElementForLinearReferencing -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/linearReferencing/rlrs#LinearElementForLinearReferencing">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity"/>
        <rdfs:comment xml:lang="en">as defined in ISO 19148:2021. It can be of type &quot;curve&quot;, &quot;edge&quot;, or &quot; feature&quot;, according to the same source.</rdfs:comment>
        <rdfs:label xml:lang="en">Linear element for linear referencing</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/linearReferencing/rlrs#LinearPosition -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/linearReferencing/rlrs#LinearPosition">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/time/time#hasTimeInterval"/>
                <owl:allValuesFrom rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Situation describing the position of an entity along a linear referent using a linear referencing method.</rdfs:comment>
        <rdfs:label>Linear position</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/linearReferencing/rlrs#LinearPositionExpression -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/linearReferencing/rlrs#LinearPositionExpression">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#InformationObject"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs#linearElement"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Generalisation of ISO 19148 PositionExpression</rdfs:comment>
        <rdfs:label>Linear position expression</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/linearReferencing/rlrs#LinearReferencingMethod -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/linearReferencing/rlrs#LinearReferencingMethod">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Method"/>
        <rdfs:subClassOf>
